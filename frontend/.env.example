# =====================================================
# FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in real values.
# Never commit .env.local.
# =====================================================

# --- API -------------------------------------------------
# Base URL of the Laravel API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_API_TIMEOUT_MS=15000

# --- App metadata -----------------------------------------
NEXT_PUBLIC_APP_NAME="Luxury Fashion"
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_APP_ENV=development

# --- Cloudinary (client-side, unsigned upload widget only) -
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- Auth ---------------------------------------------------
# Name of the cookie used to store the JWT access token
NEXT_PUBLIC_AUTH_COOKIE_NAME=lux_session

# --- Feature flags (extend as new phases are built) ---------
NEXT_PUBLIC_FEATURE_ADMIN_DASHBOARD=false
NEXT_PUBLIC_FEATURE_WISHLIST=false

# --- Analytics (Phase 9 — all optional; leave blank to disable) ---
# Each script only loads when its own id/token is present — see
# components/shared/analytics-scripts.tsx. Safe to leave every one of
# these blank in development.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

