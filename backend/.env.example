# =====================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# Generate APP_KEY with: php artisan key:generate
# Generate JWT_SECRET with: php artisan jwt:secret
# Never commit .env.
# =====================================================

APP_NAME="Luxury Fashion API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:3000

# --- Database (MySQL) ---------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=luxury_ecommerce
DB_USERNAME=root
DB_PASSWORD=

# --- JWT Auth --------------------------------------------------
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# --- CORS --------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# --- Cloudinary (media storage) -----------------------------------
FILESYSTEM_DISK=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Cache / Queue / Session ----------------------------------------
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# --- Mail (local dev logs mail instead of sending) -------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@luxury.test
MAIL_FROM_NAME="Luxury Fashion"

# --- Logging -----------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Payments (Phase 9) ---------------------------------------------
# A gateway with any required key left blank reports as "not configured"
# (see each class's isConfigured()) — the storefront's payment method
# selector greys it out instead of letting a customer pick it and hit
# an error. Cash on Delivery needs no credentials and is always available.
DEFAULT_PAYMENT_GATEWAY=cod

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# JazzCash — issued by JazzCash upon merchant onboarding
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=
JAZZCASH_SANDBOX=true

# EasyPaisa — issued by EasyPaisa upon merchant onboarding
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_RETURN_URL=
EASYPAISA_SANDBOX=true

# --- Analytics (Phase 9 — all optional, frontend-consumed) -----------
# These live in the FRONTEND's .env.local, not here, since they're
# read client-side (NEXT_PUBLIC_* vars) — see frontend/.env.example.

